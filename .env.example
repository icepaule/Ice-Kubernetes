# Ice-Kubernetes Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git!

# --- K3s Server ---
K3S_SERVER_IP=<SERVER_IP>           # e.g., 10.10.0.100
K3S_BIND_INTERFACE=<INTERFACE>      # e.g., eno1
K3S_CLUSTER_CIDR=10.42.0.0/16
K3S_SERVICE_CIDR=10.43.0.0/16

# --- MetalLB ---
METALLB_IP_RANGE=<START_IP>-<END_IP>  # e.g., 10.10.0.200-10.10.0.220

# --- NFS Storage ---
NFS_SERVER=<NFS_SERVER_IP>          # e.g., Synology NAS IP
NFS_PATH=<NFS_EXPORT_PATH>         # e.g., /volume2/k3s-data

# --- ArgoCD ---
ARGOCD_GITHUB_REPO=https://github.com/<GITHUB_USER>/Ice-Kubernetes.git

# --- Container Registry ---
REGISTRY=ghcr.io/<GITHUB_USER>

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME>

# --- Agent Nodes ---
K3S_AGENT_1_IP=<AGENT_1_IP>
K3S_AGENT_1_NAME=<AGENT_1_NAME>
